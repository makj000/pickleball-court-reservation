FIREBASE_API_KEY=                    # from rec.us web app Firebase config
EMAIL=                               # rec.us login email
REC_US_LOGIN=                        # rec.us login email (alias for EMAIL)
REC_US_PASSWORD=                     # rec.us account password
PARTICIPANT_USER_ID=                 # rec.us participant user ID used during booking

# AWS Lambda config
REGION=us-west-2
ECR_URI=                             # e.g. 123456789012.dkr.ecr.us-west-2.amazonaws.com/your-ecr-repo:latest
FUNCTION=                            # Lambda function name
UI_BUCKET=                           # S3 bucket serving ui/index.html
API_BASE=                            # API Gateway base URL for the frontend
QUEUE_NAME=                          # SQS queue name for delayed work
STATE_BUCKET=                        # S3 bucket name for state storage
PICKLEBALL_QUEUE_URL=                # SQS queue URL for delayed work

# API auth (Basic Auth for the Lambda endpoint)
API_USERNAME=
API_PASSWORD=
SYNC_SIGNING_SECRET=                 # HMAC secret for sync tokens (can reuse API_PASSWORD)

# Notifications
NOTIFY_NUMBER=
NOTIFY_EMAIL=

# Telegram bot
TELEGRAM_BOT_TOKEN=                  # from @BotFather
TELEGRAM_CHAT_ID=                    # your Telegram chat/user ID
TELEGRAM_WEBHOOK_SECRET=             # random secret for webhook verification
TELEGRAM_ALLOWED_IDS=                # comma-separated chat IDs allowed to use the bot

# Claude AI (for Telegram bot)
ANTHROPIC_API_KEY=
